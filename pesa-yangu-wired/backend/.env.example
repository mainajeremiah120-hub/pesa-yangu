# ─────────────────────────────────────────────────────────────────────────────
# Pesa Yangu — Backend Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App
NODE_ENV=production
PORT=3001

# ── Database  (Render PostgreSQL — copy from Render dashboard → External URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis  (Upstash — copy REDIS_URL from Upstash dashboard)
REDIS_URL=rediss://default:password@host.upstash.io:6379

# ── Auth  (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_with_64_char_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Anthropic  (AI Advice — Pro feature)
ANTHROPIC_API_KEY=sk-ant-...

# ── Exchange Rates  (https://exchangerate.host — free tier works)
FX_API_KEY=optional_key
FX_REFRESH_INTERVAL_HOURS=6

# ── CORS  (Vercel URL + your custom domain, comma-separated)
CORS_ORIGINS=https://pesa-yangu.vercel.app,https://pesayangu.app

# ── Rate Limiting
RATE_LIMIT_MAX=200

# ── Logging
LOG_LEVEL=info
